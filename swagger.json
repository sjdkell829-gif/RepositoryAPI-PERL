{
  "openapi": "3.0.0",
  "info": {
    "title": "Anime API CRUD Completo",
    "description": "API gestionada por Perl para niveles de poder",
    "version": "1.0.0"
  },
  "paths": {
    "/cgi-bin/api.pl": {
      "get": {
        "summary": "Listar personajes",
        "description": "Obtiene todos los personajes guardados en el archivo JSON",
        "responses": {
          "200": { "description": "Lista de personajes obtenida" }
        }
      },
      "post": {
        "summary": "Agregar personaje",
        "description": "Crea un nuevo registro. Requiere nombre, universo y nivel_poder.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nombre", "universo", "nivel_poder"],
                "properties": {
                  "nombre": { "type": "string", "example": "Saitama" },
                  "universo": { "type": "string", "example": "One Punch Man" },
                  "nivel_poder": { "type": "string", "example": "Infinito" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Creado con éxito" } }
      },
      "patch": {
        "summary": "Editar personaje",
        "description": "Busca por nombre y actualiza los campos enviados.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": { "type": "string", "description": "Nombre del personaje a editar", "example": "Saitama" },
                  "universo": { "type": "string", "example": "Héroe por Hobby" },
                  "nivel_poder": { "type": "string", "example": "Desconocido" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Actualizado con éxito" } }
      },
      "delete": {
        "summary": "Eliminar personaje",
        "description": "Elimina permanentemente a un personaje usando su nombre como ID.",
        "parameters": [
          {
            "name": "nombre",
            "in": "query",
            "required": true,
            "description": "Escribe el nombre exacto para borrar",
            "schema": { "type": "string" },
            "example": "Saitama"
          }
        ],
        "responses": { "200": { "description": "Eliminado" } }
      }
    }
  }
}