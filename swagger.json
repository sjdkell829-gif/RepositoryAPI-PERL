{
  "openapi": "3.0.0",
  "info": {
    "title": "Anime Power API",
    "version": "1.0.0",
    "description": "CRUD completo de personajes"
  },
  "paths": {
    "/cgi-bin/api.pl": {
      "get": {
        "summary": "Listar personajes",
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Agregar personaje",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": { "type": "string", "example": "Goku" },
                  "universo": { "type": "string", "example": "Dragon Ball" },
                  "nivel_poder": { "type": "string", "example": "9000" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Creado" } }
      },
      "patch": {
        "summary": "Editar personaje",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": { "type": "string", "example": "Goku" },
                  "universo": { "type": "string", "example": "DB Super" },
                  "nivel_poder": { "type": "string", "example": "Ultra Instinto" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Actualizado" } }
      },
      "delete": {
        "summary": "Eliminar personaje",
        "parameters": [
          {
            "name": "nombre",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Eliminado" } }
      }
    }
  }
}